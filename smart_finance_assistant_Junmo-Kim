        "# 🤖 AI Collaboration: Spending Analysis Function\n",
        "# AI helped create category totals, percentages, and summary metrics.\n",
        "\n",
        "def analyze_spending_patterns(df):\n",
        "    \"\"\"\n",
        "    Analyse spending patterns and generate structured finance insights.\n",
        "\n",
        "    Args:\n",
        "        df: cleaned transaction DataFrame\n",
        "\n",
        "    Returns:\n",
        "        dict: analysis results\n",
        "    \"\"\"\n",
        "    if df is None or df.empty:\n",
        "        raise ValueError(\"No transaction data provided.\")\n",
        "\n",
        "    spending_df = df[df[\"Amount\"] > 0].copy()\n",
        "    refunds_df = df[df[\"Amount\"] < 0].copy()\n",
        "\n",
        "    total_spending = float(spending_df[\"Amount\"].sum())\n",
        "    total_refunds = float(refunds_df[\"Amount\"].sum())\n",
        "\n",
        "    category_totals = spending_df.groupby(\"Category\")[\"Amount\"].sum().sort_values(ascending=False)\n",
        "    category_percentages = (category_totals / total_spending * 100).round(2) if total_spending > 0 else category_totals\n",
        "\n",
        "    top_category = category_totals.index[0] if len(category_totals) > 0 else \"None\"\n",
        "    top_amount = float(category_totals.iloc[0]) if len(category_totals) > 0 else 0.0\n",
        "\n",
        "    analysis = {\n",
        "        \"total_spending\": round(total_spending, 2),\n",
        "        \"total_refunds\": round(total_refunds, 2),\n",
        "        \"net_spending\": round(float(df[\"Amount\"].sum()), 2),\n",
        "        \"transaction_count\": int(len(df)),\n",
        "        \"category_totals\": category_totals.round(2).to_dict(),\n",
        "        \"category_percentages\": category_percentages.to_dict(),\n",
        "        \"top_category\": top_category,\n",
        "        \"top_amount\": round(top_amount, 2),\n",
        "        \"average_transaction\": round(float(spending_df[\"Amount\"].mean()), 2) if not spending_df.empty else 0.0\n",
        "    }\n",
        "    return analysis\n",
        "\n",
