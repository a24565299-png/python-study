        "def savings_goal_calculator(current_savings, monthly_contribution, target_amount):\n",
        "    \"\"\"\n",
        "    Calculate how many months are needed to reach a savings goal.\n",
        "    \"\"\"\n",
        "    current_savings = float(current_savings)\n",
        "    monthly_contribution = float(monthly_contribution)\n",
        "    target_amount = float(target_amount)\n",
        "\n",
        "    if target_amount <= current_savings:\n",
        "        return \"✅ Goal already reached.\"\n",
        "    if monthly_contribution <= 0:\n",
        "        return \"⚠️ Monthly contribution must be greater than zero.\"\n",
