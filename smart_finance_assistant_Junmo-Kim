        "# 🤖 AI Collaboration: Data Loading and Cleaning Function\n",
        "# AI helped design validation, cleaning, and error handling for messy CSV finance data.\n",
        "\n",
        "def load_and_clean_transaction_data(file_path):\n",
        "    \"\"\"\n",
        "    Load and clean transaction data for the Smart Finance Assistant.\n",
        "\n",
        "    Args:\n",
        "        file_path: CSV path, uploaded file object, or pandas DataFrame\n",
        "\n",
        "    Returns:\n",
        "        pandas.DataFrame: cleaned data with Date, Amount, Category, and Description\n",
        "    \"\"\"\n",
        "    try:\n",
        "        if isinstance(file_path, pd.DataFrame):\n",
        "            df = file_path.copy()\n",
        "        else:\n",
        "            df = pd.read_csv(file_path)\n",
        "\n",
        "        required_columns = [\"Date\", \"Amount\", \"Category\", \"Description\"]\n",
        "        missing_columns = [col for col in required_columns if col not in df.columns]\n",
        "        if missing_columns:\n",
        "            raise ValueError(f\"Missing required columns: {missing_columns}\")\n",
        "\n",
        "        df = df[required_columns].copy()\n",
        "\n",
        "        # Clean dates\n",
        "        df[\"Date\"] = pd.to_datetime(df[\"Date\"], errors=\"coerce\")\n",
        "\n",
        "        # Clean amounts such as \"$45.50\", \"-$25.00\", \"AUD 12.00\"\n",
        "        df[\"Amount\"] = (\n",
        "            df[\"Amount\"]\n",
        "            .astype(str)\n",
        "            .str.replace(\"$\", \"\", regex=False)\n",
        "            .str.replace(\"AUD\", \"\", regex=False)\n",
        "            .str.replace(\",\", \"\", regex=False)\n",
        "            .str.strip()\n",
        "        )\n",
        "        df[\"Amount\"] = pd.to_numeric(df[\"Amount\"], errors=\"coerce\")\n",
        "\n",
        "        # Clean text fields\n",
        "        df[\"Category\"] = df[\"Category\"].fillna(\"Uncategorised\").astype(str).str.strip()\n",
        "        df[\"Description\"] = df[\"Description\"].fillna(\"No description\").astype(str).str.strip()\n",
        "\n",
        "        # Remove rows where essential numeric/date data could not be read\n",
        "        df = df.dropna(subset=[\"Date\", \"Amount\"])\n",
        "\n",
        "        if df.empty:\n",
        "            raise ValueError(\"No valid transactions found after cleaning.\")\n",
        "\n",
        "        df = df.sort_values(\"Date\").reset_index(drop=True)\n",
        "        return df\n",
        "\n",
        "    except Exception as e:\n",
        "        raise ValueError(f\"Could not load and clean transaction data: {e}\")\n",
        "\n",
        "# Test the function with sample data\n",
        "clean_data = load_and_clean_transaction_data(df_sample)\n",
        "print(\"✅ Cleaned transaction data:\")\n",
        "print(clean_data)\n"
